ENVIRONMENT=development
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
INTERNAL_API_SECRET=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]

# ── Conversation (text only) ──────────────────
# Fast free option:
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-key-here

# Alternative — use OpenRouter for text too:
# AI_PROVIDER=openrouter
# (uses OPENROUTER_TEXT_MODEL)

# ── Vision (image analysis) ───────────────────
VISION_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_VISION_MODEL=meta-llama/llama-4-scout:free

# Alternative vision models (swap if hitting limits):
# OPENROUTER_VISION_MODEL=qwen/qwen-vl-32b-awq:free
# OPENROUTER_VISION_MODEL=google/gemma-3-12b:free

# ── Production ────────────────────────────────
# AI_PROVIDER=claude
# VISION_PROVIDER=claude
# VISION_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=sk-ant-...

