{
  "name": "wrench",
  "private": true,
  "scripts": {
    "dev": "docker compose up",
    "dev:web": "pnpm --filter @wrench/web dev",
    "dev:api": "cd apps/api && source ../../.venv/bin/activate && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "pnpm --filter @wrench/web build",
    "lint": "pnpm --filter @wrench/web lint && cd apps/api && source ../../.venv/bin/activate && ruff check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @wrench/web test && cd apps/api && source ../../.venv/bin/activate && pytest -v",
    "db:start":  "supabase start --workdir packages/supabase",
    "db:stop":   "supabase stop --workdir packages/supabase",
    "db:reset":  "supabase db reset --workdir packages/supabase",
    "db:migrate": "supabase migration up --workdir packages/supabase",
    "db:types": "cd packages/supabase && supabase gen types typescript --local > ../../apps/web/src/types/database.ts",
    "db:seed":   "supabase db seed --workdir packages/supabase",
    "db:studio": "supabase studio --workdir packages/supabase"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}
