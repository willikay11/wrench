{
  "name": "wrench",
  "private": true,
  "scripts": {
    "dev": "docker compose up",
    "dev:web": "pnpm --filter @wrench/web dev",
    "dev:api": "pnpm --filter @wrench/api dev",
    "build": "pnpm --filter @wrench/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @wrench/db migrate",
    "db:seed": "pnpm --filter @wrench/db seed"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}
