#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Wrench Mentor Agent — pre-commit hook
REPO_ROOT="$(git rev-parse --show-toplevel)"
MENTOR_DIR="$REPO_ROOT/tools/mentor"

# Check mentor tool is installed
if [ ! -f "$MENTOR_DIR/package.json" ]; then
  echo "⚠ Mentor tool not found — skipping review"
  exit 0
fi

# Check dependencies are installed
if [ ! -d "$MENTOR_DIR/node_modules" ]; then
  echo "⚠ Run: cd tools/mentor && npm install"
  echo "  Skipping review for this commit."
  exit 0
fi

# Check API keys are configured
if [ ! -f "$REPO_ROOT/.mentor.env" ]; then
  echo "⚠ .mentor.env not found — skipping review."
  echo "  Copy .mentor.env.example to .mentor.env"
  exit 0
fi

# Run the mentor review
cd "$MENTOR_DIR" && npx tsx src/index.ts review

exit $?