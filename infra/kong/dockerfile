FROM kong:3.6-ubuntu

COPY kong.yaml /kong/declarative/kong.yaml

ENV KONG_DATABASE=off
ENV KONG_DECLARATIVE_CONFIG=/kong/declarative/kong.yaml
ENV KONG_ADMIN_LISTEN=0.0.0.0:8001
ENV KONG_LOG_LEVEL=info
ENV KONG_PROXY_ACCESS_LOG=/dev/stdout
ENV KONG_ADMIN_ACCESS_LOG=/dev/stdout
ENV KONG_PROXY_ERROR_LOG=/dev/stderr
ENV KONG_ADMIN_ERROR_LOG=/dev/stderr

RUN kong config parse /kong/declarative/kong.yaml

EXPOSE 8000 8001

# Use Railway's PORT variable for proxy listen
CMD ["sh", "-c", "KONG_PROXY_LISTEN=0.0.0.0:${PORT:-8000} kong start --vv"]
